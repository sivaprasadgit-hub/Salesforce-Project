<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Date_of_Birth_validation</fullName>
    <active>true</active>
    <errorConditionFormula>OR( Date_of_Birth__c &gt; TODAY(), ((TODAY()- Date_of_Birth__c)/365) &lt; 15)</errorConditionFormula>
    <errorDisplayField>Date_of_Birth__c</errorDisplayField>
    <errorMessage>Date of birth must be in Past</errorMessage>
</ValidationRule>
