<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>College_Left_Date</fullName>
    <active>true</active>
    <errorConditionFormula>AND (ISPICKVAL( Alumini__c , &quot;NO&quot;), NOT( ISNULL( College_Left_Date__c ) ))</errorConditionFormula>
    <errorDisplayField>College_Left_Date__c</errorDisplayField>
    <errorMessage>College left date cannot be populated, if student is not a Alumni</errorMessage>
</ValidationRule>
