<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Expire_date_for_KYC</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(Expiry_Date__c &gt; TODAY())</errorConditionFormula>
    <errorDisplayField>Expiry_Date__c</errorDisplayField>
    <errorMessage>Expire date for KYC must be greater than today</errorMessage>
</ValidationRule>
